# Development image — matches Ruby version pinned in .tool-versions.
FROM ruby:3.4.8-slim

ENV RAILS_ENV=development \
    BUNDLE_PATH=/usr/local/bundle \
    LANG=C.UTF-8

# System deps: build native gems (pg, ffi), image processing (vips), git for bundler.
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    libyaml-dev \
    libvips \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Match the bundler pinned in Gemfile.lock. Gems are installed at runtime into a
# named volume (see compose.yaml), so code and gems are not baked into the image.
RUN gem install bundler -v 4.0.16

EXPOSE 3000

CMD ["bin/rails", "server", "-b", "0.0.0.0"]
