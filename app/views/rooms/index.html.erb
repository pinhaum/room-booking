<div class="max-w-3xl mx-auto w-full">
  <% if flash[:notice] %>
    <p class="mb-4 rounded bg-green-100 text-green-800 px-3 py-2 text-sm"><%= flash[:notice] %></p>
  <% end %>

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-semibold">Salas</h1>
    <% if RoomPolicy.new(current_user, Room).create? %>
      <%= link_to "Nova sala", new_room_path, class: "rounded bg-gray-800 text-white px-3 py-2 text-sm" %>
    <% end %>
  </div>

  <%= form_with url: rooms_path, method: :get, class: "flex flex-wrap gap-2 mb-6" do |f| %>
    <%= f.text_field :name, value: params[:name], placeholder: "Nome",
          class: "rounded border px-2 py-1 text-sm" %>
    <%= f.number_field :min_capacity, value: params[:min_capacity], placeholder: "Capacidade mín.",
          class: "rounded border px-2 py-1 text-sm w-40" %>
    <label class="flex items-center gap-1 text-sm">
      <%= f.check_box :available, { checked: params[:available].present? }, "true", nil %>
      Somente disponíveis
    </label>
    <%= f.submit "Filtrar", class: "rounded bg-gray-200 px-3 py-1 text-sm cursor-pointer" %>
  <% end %>

  <% if @rooms.any? %>
    <ul class="divide-y">
      <% @rooms.each do |room| %>
        <li class="py-3 flex items-center justify-between">
          <div>
            <%= link_to room.name, room_path(room), class: "font-medium text-blue-700" %>
            <span class="text-gray-500 text-sm">· <%= room.capacity %> pessoas</span>
            <% unless room.available? %>
              <span class="ml-2 text-xs rounded bg-red-100 text-red-700 px-2 py-0.5">indisponível</span>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-600">Nenhuma sala encontrada.</p>
  <% end %>
</div>
