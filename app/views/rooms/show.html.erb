<div class="max-w-2xl mx-auto w-full">
  <% if flash[:notice] %>
    <p class="mb-4 rounded bg-green-100 text-green-800 px-3 py-2 text-sm"><%= flash[:notice] %></p>
  <% end %>

  <h1 class="text-2xl font-semibold mb-2"><%= @room.name %></h1>
  <p class="text-gray-600 mb-1">Capacidade: <%= @room.capacity %> pessoas</p>
  <p class="text-gray-600 mb-4">Status: <%= @room.available? ? "disponível" : "indisponível" %></p>
  <% if @room.description.present? %>
    <p class="text-gray-800 mb-6"><%= @room.description %></p>
  <% end %>

  <div class="flex gap-2">
    <%= link_to "Voltar", rooms_path, class: "rounded bg-gray-200 px-3 py-2 text-sm" %>
    <% if RoomPolicy.new(current_user, @room).update? %>
      <%= link_to "Editar", edit_room_path(@room), class: "rounded bg-gray-800 text-white px-3 py-2 text-sm" %>
    <% end %>
    <% if RoomPolicy.new(current_user, @room).destroy? %>
      <%= button_to "Remover", room_path(@room), method: :delete,
            class: "rounded bg-red-700 text-white px-3 py-2 text-sm",
            data: { turbo_confirm: "Remover esta sala?" } %>
    <% end %>
  </div>
</div>
