<%= form_with model: room, class: "space-y-4" do |f| %>
  <% if room.errors.any? %>
    <div class="rounded bg-red-100 text-red-800 px-3 py-2 text-sm">
      <ul class="list-disc list-inside">
        <% room.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :name, class: "w-full rounded border px-2 py-1" %>
  </div>

  <div>
    <%= f.label :capacity, class: "block text-sm font-medium mb-1" %>
    <%= f.number_field :capacity, class: "w-full rounded border px-2 py-1" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full rounded border px-2 py-1" %>
  </div>

  <label class="flex items-center gap-2 text-sm">
    <%= f.check_box :available %>
    <%= f.label :available %>
  </label>

  <div class="flex gap-2">
    <%= f.submit class: "rounded bg-gray-800 text-white px-3 py-2 text-sm cursor-pointer" %>
    <%= link_to "Cancelar", rooms_path, class: "rounded bg-gray-200 px-3 py-2 text-sm" %>
  </div>
<% end %>
