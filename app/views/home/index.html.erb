<div class="max-w-2xl mx-auto mt-16">
  <% if flash[:notice] %>
    <p class="mb-4 rounded bg-green-100 text-green-800 px-3 py-2 text-sm"><%= flash[:notice] %></p>
  <% end %>

  <h1 class="text-2xl font-semibold mb-4">Olá, <%= current_user.name %></h1>
  <p class="text-gray-600 mb-6">Você está autenticado como <%= current_user.email %>.</p>

  <%= button_to "Sair", logout_path, method: :delete,
        class: "rounded bg-gray-800 text-white px-3 py-2" %>
</div>
